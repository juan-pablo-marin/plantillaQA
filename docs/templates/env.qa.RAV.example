# Copia a la raíz del proyecto como .env.qa (no se sube a git por .gitignore)
# Ver: docs/RAV-FUC-QA.md

PROJECT_NAME=rav-qa-stack
ENVIRONMENT=qa

BACKEND_DIR=BACKENDRAV 
FRONTEND_DIR=FRONTENDRAV

BACKEND_PORT=8082
FRONTEND_PORT=3000
BACKEND_INTERNAL_PORT=8082

DB_PORT=5432
POSTGRES_USER=rav_admin
POSTGRES_PASSWORD=rav_changeme_cambiar
POSTGRES_DB=db_ruv

SERVER_WRITE_TIMEOUT=420
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000
JWT_SECRET=cambiar-en-env-qa-minimo-64-caracteres-recomendado-para-rav-seguridad-qa
UPLOAD_PATH=/tmp/rav-qa-uploads

FRONTEND_TARGET=runner

BUILD_VERSION=dev
BUILD_DATE=unknown

SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=
PROJECT_KEY=rav-qa
SONAR_WAIT_SECONDS=300
SONAR_SCAN_TIMEOUT=20m

GIT_PULL_ENABLED=false
BACKEND_REPO_URL=
FRONTEND_REPO_URL=

RUN_NEWMAN=false
RUN_SONAR=false
RUN_PLAYWRIGHT=false
RUN_K6=false
RUN_JENKINS=false

JENKINS_PORT=8085

DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
