# Copia a la raíz del proyecto como .env.qa_fuc
# Uso: docker compose --env-file .env.qa_fuc -f docker-compose.qa_fuc.yml up -d

PROJECT_NAME=fuc-qa-stack
ENVIRONMENT=qa

BACKEND_DIR=BACKEND
FRONTEND_DIR=FRONTEND

BACKEND_PORT=8080
FRONTEND_PORT=3000
DB_PORT=27017

MONGO_USER=appuser
MONGO_PASSWORD=changeme
MONGO_DB=mydb

FRONTEND_TARGET=runtime

BUILD_VERSION=dev
BUILD_DATE=unknown

SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=
PROJECT_KEY=qa-project
SONAR_WAIT_SECONDS=300
SONAR_SCAN_TIMEOUT=20m

GIT_PULL_ENABLED=false
BACKEND_REPO_URL=
FRONTEND_REPO_URL=

RUN_NEWMAN=false
RUN_SONAR=false
RUN_PLAYWRIGHT=false
RUN_K6=false
RUN_JENKINS=false

JENKINS_PORT=8085

DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
