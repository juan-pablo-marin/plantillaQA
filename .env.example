# ============================================
# Archivo de ejemplo — QA Factory Template
# Copia como .env.dev, .env.staging o .env.qa
#
# QA tiene dos perfiles:
#   RAV   → docs/templates/env.qa.RAV.example  → docker-compose.qa.yml
#   FUC   → docs/templates/env.qa.FUC.example  → docker-compose.qa_fuc.yml
# Ver: docs/RAV-FUC-QA.md
# ============================================

# --- Proyecto ---
PROJECT_NAME=mi-proyecto
BACKEND_DIR=BACKEND
FRONTEND_DIR=FRONTEND

ENVIRONMENT=qa

# --- Puertos ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
DB_PORT=27017

# --- MongoDB ---
MONGO_USER=appuser
MONGO_PASSWORD=changeme
MONGO_DB=mydb

# --- Build ---
BUILD_VERSION=dev
BUILD_DATE=unknown
# Next.js multi-stage: stage de producción habitual = production
FRONTEND_TARGET=production

# --- SonarQube ---
# Tras el primer arranque: http://localhost:9000 (admin/admin)
# Crear proyecto, generar token y pegarlo aqui
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=
PROJECT_KEY=mi-proyecto
SONAR_WAIT_SECONDS=300

# --- Git Pull (para CI/Kubernetes) ---
GIT_PULL_ENABLED=false
BACKEND_REPO_URL=
FRONTEND_REPO_URL=

# --- Test Execution Flags ---
RUN_NEWMAN=false
RUN_SONAR=false
RUN_PLAYWRIGHT=false
RUN_K6=false
RUN_JENKINS=false

# --- Jenkins ---
JENKINS_PORT=8085

# --- Notificaciones (ChatOps) ---
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
