  "item": [
    {
      "name": "00 — Smoke",
      "item": [
        {
          "name": "GET / — servidor activo",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Servidor responde (404 o 200 en raíz)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([404, 200]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
