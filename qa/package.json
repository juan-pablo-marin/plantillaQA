{
  "name": "qa-runner",
  "version": "1.0.0",
  "private": true,
  "description": "Suite QA - Template",
  "scripts": {
    "test:api": "newman run api/collections/api.postman_collection.json --environment api/collections/env-qa.json",
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "test:perf": "k6 run performance/k6-tests.js",
    "report:newman": "npx --yes serve reports/newman -l 8181"
  },
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "allure-playwright": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
