# Contexto Docker (raíz del repo) — usado por qa/docker/Dockerfile.rav-backend (COPY BACKEND_DIR)
# Evitar patrones demasiado amplios: antes Dockerfile* y *.json excluían rutas del backend Go.

# Node.js
**/node_modules/
**/npm-debug.log
**/yarn-error.log
**/.pnpm-store
**/.next/
**/out/
**/build/
**/dist/

# Python
__pycache__/
*.pyc
*.pyo

# Go — solo artefactos típicos en la raíz del repo (no carpetas pkg/ del código fuente)
/bin/
/pkg/

# Docker — solo Dockerfile en la raíz (no "Dockerfile*" → rompe exclusiones raras)
/Dockerfile

# Version Control
.git/
.gitignore

# QA & Build Artifacts
qa/reports/
qa/src_backend/
qa/src_frontend/
*coverage.out
qa/reports/**/*.xml
qa/reports/**/*.json

# IDE
.vscode/
.idea/

# Environment Variables
.env
.env.*
!.env.example

# Módulo Go siempre incluido (por si algún patrón anterior afecta)
!**/go.mod
!**/go.sum
